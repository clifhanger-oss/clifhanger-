{
  "name": "cliffhanger",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Cliffhanger — Climbing Equipments & Outdoor Gears. Made for the vertical.",
  "scripts": {
    "dev": "vite",
    "build": "npm run generate:sitemap && tsc -b && vite build && npm run prerender",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "prerender": "node scripts/prerender-routes.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@react-three/fiber": "^9.6.1",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.545.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.3.1",
    "three": "^0.185.1",
    "wouter": "^3.10.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.7.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.1.14",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.2",
    "vitest": "^3.2.7"
  }
}
